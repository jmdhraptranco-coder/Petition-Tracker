APP_ENV=production
SECRET_KEY=replace-with-strong-random-secret

# Option A (preferred): full DSN from DBA
# DATABASE_URL=postgresql://db_user:db_password@db_host:5432/vigilance_tracker

# Option B: separate DB fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vigilance_tracker
DB_USER=postgres
DB_PASSWORD=change-me
DB_SSLMODE=require
DB_CONNECT_TIMEOUT=10

HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0

BRAND_NAME=Nigaa
BRAND_SUBTITLE=Petition Tracker
# Put your logo file inside static/ and give relative path under static.
# Example: static/img/nigaa-logo.svg -> BRAND_LOGO_FILE=img/nigaa-logo.svg
BRAND_LOGO_FILE=img/nigaa-logo.svg
BRAND_LOGO_FALLBACK=img/aptransco-logo-fallback.svg

# File storage path for uploads.
# Examples:
# FILE_STORAGE_PATH=uploads
# FILE_STORAGE_PATH=C:/PetitionTracker/uploads
# FILE_STORAGE_PATH=//fileserver01/petition-tracker/uploads
# (legacy alias still supported: UPLOAD_BASE_DIR)
FILE_STORAGE_PATH=uploads
MAX_UPLOAD_SIZE_MB=10
SESSION_LIFETIME_MINUTES=60
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_NAME=__Host-nigaa_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_PATH=/
SESSION_INACTIVITY_MINUTES=30
SESSION_ABSOLUTE_HOURS=24
SESSION_TOUCH_THRESHOLD_SECONDS=300
MAX_CONCURRENT_SESSIONS=3
REVOKE_OTHER_SESSIONS_ON_LOGIN=0
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=8
LOGIN_RATE_LIMIT_BLOCK_SECONDS=900
TRUST_PROXY_HEADERS=1
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
